{
    "layer": "top",
    "position": "bottom",
    "exclusive": false,
    "height": 40,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,
    "spacing": 4,
    "reload_style_on_change": true,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "cpu",
        "memory",
        "temperature",
        "power-profiles-daemon",
        "network",
        "bluetooth",
        "backlight",
        "wireplumber",
        "battery",
        "custom/power"
    ],
    "hyprland/workspaces": {
        "format": "{id}",
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1",
        "on-click": "activate",
        "sort-by-number": true,
        "persistent-workspaces": {
            "*": [
                1,
                2,
                3,
                4,
                5
            ]
        }
    },
    "hyprland/window": {
        "format": "{}",
        "max-length": 40,
        "separate-outputs": true,
        "rewrite": {
            "(.*) â€” Mozilla Firefox": "َ°ˆ¹  $1",
            "(.*) - kitty": "َ°†چ  $1",
            "": "َ°چ¹  Desktop"
        }
    },
    "clock": {
        "format": "َ°…گ  {0:%I:%M %p}   َ°ƒ­  {0:%a %d %b}",
        "tooltip-format": "<big>{0:%Y %B}</big>\n<tt><small>{0:%A, %d %B %Y}</small></tt>"
    },
    "cpu": {
        "interval": 2,
        "format": "َ°»   {usage}%",
        "tooltip": true,
        "on-click": "kitty -e top"
    },
    "memory": {
        "interval": 5,
        "format": "َ°چ›  {percentage}%",
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G   ({percentage}%)\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "on-click": "kitty -e top"
    },
    "temperature": {
        "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
        "input-filename": "temp1_input",
        "interval": 2,
        "critical-threshold": 85,
        "format": "{icon}  {temperatureC}آ°C",
        "format-critical": "{icon}  {temperatureC}آ°C",
        "format-icons": [
            "َ°”گ",
            "َ°”ڈ",
            "َ°”ڈ",
            "َ°”‘",
            "َ°”‘"
        ],
        "tooltip": true
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip": true,
        "tooltip-format": "Power mode: {profile}\nClick to switch (saver â†’ balanced â†’ performance)",
        "format-icons": {
            "default": "َ°“…",
            "power-saver": "َ°Œھ",
            "balanced": "َ°—‘",
            "performance": "َ±“‍"
        }
    },
    "network": {
        "format-wifi": "َ°–©",
        "format-ethernet": "َ°ˆ€",
        "format-disconnected": "َ°–ھ",
        "format-linked": "َ°–©",
        "tooltip-format-wifi": "َ°–©  {essid}\nSignal: {signalStrength}%\nIP: {ipaddr}",
        "tooltip-format-ethernet": "َ°ˆ€  {ifname}\nIP: {ipaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "nm-connection-editor",
        "max-length": 20
    },
    "bluetooth": {
        "format": "َ°‚¯",
        "format-connected": "َ°‚±  {device_alias}",
        "format-connected-battery": "َ°‚±  {device_alias} {device_battery_percentage}%",
        "format-off": "َ°‚²",
        "tooltip-format": "Bluetooth: {status}\n{controller_alias}",
        "tooltip-format-connected": "{controller_alias}\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}  {device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}  {device_address}  {device_battery_percentage}%",
        "on-click": "blueman-manager"
    },
    "backlight": {
        "format": "{icon}  {percent}%",
        "format-icons": [
            "َ°ƒ›",
            "َ°ƒœ",
            "َ°ƒ‌",
            "َ°ƒ‍",
            "َ°ƒں",
            "َ°ƒ "
        ],
        "on-scroll-up": "brightnessctl -e4 -n2 set 5%+",
        "on-scroll-down": "brightnessctl -e4 -n2 set 5%-",
        "tooltip": true,
        "tooltip-format": "Screen brightness: {percent}%"
    },
    "wireplumber": {
        "format": "{icon}  {volume}%",
        "format-muted": "َ°‌ں  muted",
        "format-icons": [
            "َ°•؟",
            "َ°–€",
            "َ°•¾"
        ],
        "on-scroll-up": "wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "tooltip": true,
        "tooltip-format": "Volume: {volume}%\nNode: {node_name}"
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "َ°‚„  {capacity}%",
        "format-plugged": "َ°ڑ¥  {capacity}%",
        "format-full": "َ°پ¹  {capacity}%",
        "format-icons": [
            "َ°پ»",
            "َ°پ½",
            "َ°پ؟",
            "َ°‚پ",
            "َ°پ¹"
        ],
        "tooltip-format": "Battery: {capacity}%\nHealth: {health}%\n{timeTo}\nPower draw: {power}W"
    },
    "custom/power": {
        "format": "َ°گ¥",
        "tooltip": false,
        "on-click": "wlogout -b 3"
    }
}
