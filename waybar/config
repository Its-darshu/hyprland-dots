{
    "layer": "top",
    "position": "top",
    "exclusive": false,
    "height": 40,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,
    "spacing": 4,
    "reload_style_on_change": true,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "cpu",
        "memory",
        "temperature",
        "power-profiles-daemon",
        "network",
        "bluetooth",
        "backlight",
        "battery",
        "custom/power"
    ],
    "hyprland/workspaces": {
        "format": "{id}",
        "on-scroll-up": "hyprctl dispatch workspace e-1",
        "on-scroll-down": "hyprctl dispatch workspace e+1",
        "on-click": "activate",
        "sort-by-number": true,
        "persistent-workspaces": {
            "*": [
                1,
                2,
                3,
                4,
                5
            ]
        }
    },
    "hyprland/window": {
        "format": "{}",
        "max-length": 40,
        "separate-outputs": true,
        "rewrite": {
            "(.*) ÔÇö Mozilla Firefox": "¾░ê╣  $1",
            "(.*) - kitty": "¾░åı  $1",
            "": "¾░ı╣  Desktop"
        }
    },
    "clock": {
        "format": "¾░àÉ  {0:%I:%M %p}   ¾░â¡  {0:%a %d %b}",
        "tooltip-format": "<big>{0:%Y %B}</big>\n<tt><small>{0:%A, %d %B %Y}</small></tt>"
    },
    "cpu": {
        "interval": 2,
        "format": "¾░╗á  {usage}%",
        "tooltip": true,
        "on-click": "kitty -e top"
    },
    "memory": {
        "interval": 5,
        "format": "¾░ıø  {percentage}%",
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G   ({percentage}%)\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "on-click": "kitty -e top"
    },
    "temperature": {
        "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
        "input-filename": "temp1_input",
        "interval": 2,
        "critical-threshold": 85,
        "format": "{icon}  {temperatureC}┬░C",
        "format-critical": "{icon}  {temperatureC}┬░C",
        "format-icons": [
            "¾░öÉ",
            "¾░öÅ",
            "¾░öÅ",
            "¾░öæ",
            "¾░öæ"
        ],
        "tooltip": true
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip": true,
        "tooltip-format": "Power mode: {profile}\nClick to switch (saver ÔåÆ balanced ÔåÆ performance)",
        "format-icons": {
            "default": "¾░ôà",
            "power-saver": "¾░î¬",
            "balanced": "¾░ùæ",
            "performance": "¾▒ôŞ"
        }
    },
    "network": {
        "format-wifi": "¾░û®",
        "format-ethernet": "¾░êÇ",
        "format-disconnected": "¾░û¬",
        "format-linked": "¾░û®",
        "tooltip-format-wifi": "¾░û®  {essid}\nSignal: {signalStrength}%\nIP: {ipaddr}",
        "tooltip-format-ethernet": "¾░êÇ  {ifname}\nIP: {ipaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "nm-connection-editor",
        "max-length": 20
    },
    "bluetooth": {
        "format": "¾░é»",
        "format-connected": "¾░é▒  {device_alias}",
        "format-connected-battery": "¾░é▒  {device_alias} {device_battery_percentage}%",
        "format-off": "¾░é▓",
        "tooltip-format": "Bluetooth: {status}\n{controller_alias}",
        "tooltip-format-connected": "{controller_alias}\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}  {device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}  {device_address}  {device_battery_percentage}%",
        "on-click": "blueman-manager"
    },
    "backlight": {
        "format": "{icon}  {percent}%",
        "format-icons": [
            "¾░âø",
            "¾░â£",
            "¾░âØ",
            "¾░âŞ",
            "¾░âş",
            "¾░âá"
        ],
        "on-scroll-up": "brightnessctl -e4 -n2 set 5%+",
        "on-scroll-down": "brightnessctl -e4 -n2 set 5%-",
        "tooltip": true,
        "tooltip-format": "Screen brightness: {percent}%"
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "¾░éä  {capacity}%",
        "format-plugged": "¾░ÜÑ  {capacity}%",
        "format-full": "¾░ü╣  {capacity}%",
        "format-icons": [
            "¾░ü╗",
            "¾░ü¢",
            "¾░ü┐",
            "¾░éü",
            "¾░ü╣"
        ],
        "tooltip-format": "Battery: {capacity}%\nHealth: {health}%\n{timeTo}\nPower draw: {power}W"
    },
    "custom/power": {
        "format": "¾░ÉÑ",
